{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofti.dev/schemas/ofti.queue-record.v1.schema.json",
  "title": "OFTI Queue Record v1",
  "type": "object",
  "required": ["format", "format_version", "queue_id", "planned", "finished", "summary"],
  "properties": {
    "format": {"const": "ofti.queue-record"},
    "format_version": {"const": 1},
    "queue_id": {"type": ["string", "null"]},
    "backend": {"type": ["string", "null"]},
    "ok": {"type": "boolean"},
    "planned": {"type": "array"},
    "started": {"type": "array"},
    "finished": {"type": "array"},
    "failed_to_start": {"type": "array"},
    "summary": {"type": "object"}
  },
  "additionalProperties": true
}
