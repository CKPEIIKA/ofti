{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofti.dev/schemas/ofti.case-bundle.v1.schema.json",
  "title": "OFTI Case Bundle Manifest v1",
  "type": "object",
  "required": ["format", "format_version", "case_name", "start_time", "mesh_policy", "application", "files"],
  "properties": {
    "format": {"const": "ofti.case-bundle"},
    "format_version": {"const": 1},
    "version": {"const": 1},
    "case_name": {"type": "string"},
    "start_time": {"type": "string"},
    "mesh_policy": {"enum": ["auto", "include", "exclude"]},
    "application": {"type": "string"},
    "header_version": {"type": "string"},
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": {"type": "string"},
          "size": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
