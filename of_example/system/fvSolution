FoamFile
{
    version         2;
    format          ascii;
    class           dictionary;
    location        "system";
    object          fvSolution;
}

solvers
{
    "(rho|rhoU|rhoE|rhoEv.*)"
    {
        solver          diagonal;
    }
    U
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        nSweeps         1;
        tolerance       1e-09;
        relTol          0.0001;
    }
    "(h|e).*"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        nSweeps         2;
        tolerance       1e-10;
        relTol          0.001;
        minIter         1;
        maxIter         400;
    }
    Yi
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-12;
        relTol          0;
        maxIter         10;
    }
    "(k|omega|epsilon)"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        nSweeps         2;
        tolerance       1e-15;
        relTol          1e-07;
        minIter         1 maxIter 20;
    }
}


