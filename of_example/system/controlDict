// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
FoamFile        FoamFile;

application     hy2Foam;

startFrom       startFrom 6;

startTime       startTime 5;

stopAt          endTime;

endTime         1e-05;

deltaT          1e-10;

writeControl    adjustableRunTime;

writeInterval   0.0001;

purgeWrite      10;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   10;

runTimeModifiable true;

adjustTimeStep  yes;

maxCo           0.2;

maxDeltaT       1e-05;

libs            ( "libstrathFiniteVolume.so" );

functions       ;


